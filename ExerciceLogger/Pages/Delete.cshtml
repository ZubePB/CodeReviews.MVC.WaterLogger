@page
@model ExerciceLogger.Pages.DeleteModel
@{
    ViewData["Title"] = "Delete";
}
@try{
{
    @if (Model.Exercice == null)
        throw (new Exception("Can't reach the database or the data might not be retrieved from it. Verify that the database and the table exists, and the connection settings."));
    <h3>Are you sure you want to delete this record?</h3>

<div>
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(Model => Model.Exercice.Type)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(Model => Model.Exercice.Type)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(Model => Model.Exercice.Date)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(Model => Model.Exercice.Date)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(Model => Model.Exercice.Reps)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(Model => Model.Exercice.Reps)
        </dd>
    </dl>
</div>

<form method="post" class="form-group">
    <input type="hidden" asp-for="Exercice.Id"/>
    <input type="submit" value="Delete" class="btn btn-danger m-2 ms-0" /><br />
    <a asp-page="./Index" class="btn btn-secondary">Back To List</a>
    </form>
}
}
catch(Exception ex)
{
    <p>
        <strong>An error occured: </strong>@ex.Message
    </p>
}